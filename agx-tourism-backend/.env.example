# ============================================================================
# AGX TOURISM ENGINE - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this to .env and fill in your actual values

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Microservice port assignments
INTENT_SERVICE_PORT=3001
PLANNING_SERVICE_PORT=3002
BOOKING_SERVICE_PORT=3003
KG_SERVICE_PORT=3004
MONITOR_SERVICE_PORT=3005
EXPLANATION_SERVICE_PORT=3006

# Environment (development, staging, production)
NODE_ENV=development
LOG_LEVEL=info

# ============================================================================
# SERP API CONFIGURATION (Real-time tourism data)
# ============================================================================
# Get your free API key from: https://serpapi.com/
# Free tier: 100 requests/day
# Pricing: https://serpapi.com/pricing

SERP_API_KEY=your_serp_api_key_here

# ============================================================================
# DATABASE CONFIGURATION - NEO4J (Knowledge Graph)
# ============================================================================
# Neo4j is used for semantic relationships between tourism entities
# Installation: https://neo4j.com/download/

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ============================================================================
# VECTOR DATABASE CONFIGURATION - PINECONE (RAG Embeddings)
# ============================================================================
# Pinecone stores vector embeddings for semantic search
# Sign up: https://www.pinecone.io/

PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp  # or your region
PINECONE_INDEX_NAME=agx-tourism-embeddings

# ============================================================================
# LLM CONFIGURATION - CLAUDE (Multi-agent Orchestration)
# ============================================================================
# Claude 3.5 Sonnet is used for agentic reasoning across all services
# Get your API key: https://console.anthropic.com/

ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# BOOKING SERVICE INTEGRATIONS
# ============================================================================
# Third-party APIs for actual booking execution

# Booking.com
BOOKING_COM_API_KEY=your_booking_api_key_here
BOOKING_COM_PARTNER_ID=your_partner_id_here

# MakeMyTrip (Indian platform)
MAKEMYTRIP_API_KEY=your_makemytrip_api_key_here

# Google Maps (Navigation & distance calculation)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================================
# CACHING & QUEUE CONFIGURATION
# ============================================================================
# Redis for caching, rate limiting, and job queues

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL settings (in seconds)
CACHE_TTL_ATTRACTIONS=86400      # 24 hours
CACHE_TTL_EVENTS=3600             # 1 hour (events change frequently)
CACHE_TTL_WEATHER=1800            # 30 minutes
CACHE_TTL_SERP_RESULTS=7200       # 2 hours

# Job queue (BullMQ)
JOB_QUEUE_NAME=agx-tourism-jobs
JOB_QUEUE_MAX_CONCURRENCY=5

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret for API authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100     # per window

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8000

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# ELK Stack (Elasticsearch, Logstash, Kibana)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=agx-tourism-logs

# Datadog or similar APM
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_ENV=development

# ============================================================================
# EMAIL CONFIGURATION (Booking confirmations, notifications)
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@agxtourism.com

# ============================================================================
# STORAGE CONFIGURATION (Itinerary PDFs, documents)
# ============================================================================

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=agx-tourism-docs
AWS_REGION=us-west-2

# Or use local storage
STORAGE_TYPE=local  # local | s3
STORAGE_LOCAL_PATH=./storage/documents

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features for testing and gradual rollout

FEATURE_REAL_TIME_REPLANNING=true
FEATURE_MULTI_AGENT_ORCHESTRATION=true
FEATURE_SERP_API_INTEGRATION=true
FEATURE_BOOKING_EXECUTION=false     # Keep false until Phase 2 complete
FEATURE_WEBSOCKET_MONITORING=false  # Keep false until Phase 4 complete

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Debug mode (logs detailed information)
DEBUG=agx:*

# Mock external APIs (for testing without real API calls)
MOCK_SERP_API=false
MOCK_BOOKING_API=false
MOCK_MAPS_API=false

# ============================================================================
# KNOWLEDGE GRAPH SEED DATA
# ============================================================================

# Path to seed data files for initial Neo4j population
KG_SEED_DATA_PATH=./data/seed/tourism-data.json
KG_SEED_ON_STARTUP=false

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Connection pool sizes
DB_POOL_MIN=2
DB_POOL_MAX=10

# Timeout values (milliseconds)
API_TIMEOUT=10000
DB_TIMEOUT=5000
SERP_API_TIMEOUT=10000

# Batch processing
BATCH_SIZE_KG_QUERIES=50
BATCH_SIZE_VECTOR_EMBEDDINGS=100
