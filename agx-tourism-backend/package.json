{
  "name": "agx-tourism-engine-backend",
  "version": "1.0.0",
  "description": "Agentic Explainable AI Tourism Planning Engine - Microservices Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint .",
    "format": "prettier --write .",
    "logs:intent": "tail -f logs/intent-service-combined.log",
    "logs:planning": "tail -f logs/planning-service-combined.log",
    "docker:build": "docker build -t agx-tourism-backend:latest .",
    "docker:run": "docker run -p 3001:3001 -p 3002:3002 -p 3003:3003 -p 3004:3004 -p 3005:3005 -p 3006:3006 agx-tourism-backend:latest"
  },
  "keywords": [
    "tourism",
    "AI",
    "agentic",
    "itinerary",
    "planning"
  ],
  "author": "Your Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "redis": "^4.6.12",
    "neo4j-driver": "^5.13.0",
    "pg": "^8.11.3",
    "bullmq": "^5.0.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.6",
    "mocha": "^10.2.0",
    "chai": "^4.3.10"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourrepo/agx-tourism-backend.git"
  }
}
