APP_NAME=AGX Tourism Engine
APP_ENV=dev
API_V1_PREFIX=/v1
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg2://agx:agx@postgres:5432/agx_tourism
REDIS_URL=redis://redis:6379/0
# Preferred key name
SERP_API_KEY=
# Backward-compatible alias
SERPAPI_API_KEY=
SERP_ENABLED=false
SERP_FALLBACK_MIN_RESULTS=3
SERP_FALLBACK_CONFIDENCE_THRESHOLD=0.6
HTTP_TIMEOUT_SECONDS=8
ENABLE_BACKGROUND_MONITOR=true
